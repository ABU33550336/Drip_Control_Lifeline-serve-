.container {
  padding: 20rpx;
  background-color: #e0e0e0;
  min-height: 100vh;
}

.header {
  text-align: center;
  background-color: #0066cc;
  color: white;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  margin-top: 10rpx;
  display: block;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
  color: #333;
}

.data-box, .chart-box, .control-box, .threshold-box, .speed-box, .log-box {
  background-color: white;
  margin: 20rpx 0;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.data-row {
  display: flex;
  justify-content: space-around;
  margin: 20rpx 0;
}

.data-item {
  text-align: center;
  flex: 1;
}

.data-label {
  font-size: 28rpx;
  color: #666;
  display: block;
}

.data-value {
  font-size: 80rpx;
  color: #0066cc;
  font-weight: bold;
  line-height: 1.2;
}

.data-unit {
  font-size: 24rpx;
  color: #999;
}


.drip-item .data-value,
.drip-item .data-unit {
    transform: translateX(30rpx);
    display: inline-block;
}

.alarm-box {
  text-align: center;
  margin-top: 20rpx;
}

.alarm-text {
  background-color: red;
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-weight: bold;
  display: inline-block;
}

.canvas {
  width: 100%;
  height: 400rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
}

.btn-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin: 20rpx 0;
}

.btn {
  background-color: #0066cc;
  color: white;
  border: none;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.btn-red {
  background-color: #cc0000;
}

.btn-green {
  background-color: #00cc00;
}

.threshold-row {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
  font-size: 28rpx;
}

.threshold-row text {
  width: 180rpx;
}

.threshold-row input {
  flex: 1;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin: 0 20rpx;
  font-size: 28rpx;
  text-align: center;
}

.log-scroll {
  height: 300rpx;
  background-color: #222;
  color: #0f0;
  padding: 20rpx;
  border-radius: 12rpx;
  font-family: monospace;
  font-size: 24rpx;
}

.log-item {
  white-space: pre-wrap;
  word-break: break-all;
  margin-bottom: 8rpx;
}